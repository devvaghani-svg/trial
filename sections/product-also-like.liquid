{% stylesheet %}
.also-like {
  padding: 60px 80px;
  background: #F9F3F1;
}

.also-like__inner {
  max-width: 1280px;
  margin: 0 auto;
}

.also-like__heading {
  font-size: 36px;
  font-weight: 700;
  margin-bottom: 48px;
  color: #3a3a3e;
}

/* Desktop: 4 cards, 305x469 each, 20px gap */
.also-like__grid {
  display: grid;
  grid-template-columns: repeat(4, 305px);
  gap: 20px;
}

.also-like-card {
  border: 0.6px solid #3a3a3e;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.also-like-card__image-wrap {
  width: 100%;
  aspect-ratio: 305 / 305;
  overflow: hidden;
  background: #eee;
}

.also-like-card__image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.also-like-card__body {
  padding: 16px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.also-like-card__title {
  font-size: 16px;
  font-weight: 600;
  color: #3a3a3e;
  margin: 0;
}

.also-like-card__price {
  font-size: 16px;
  font-weight: 700;
  color: #E52888;
  margin: 0;
}

.also-like-card__btn {
  display: block;
  margin-top: auto;
  text-align: center;
  background: #025A60;
  color: #fff;
  padding: 10px 16px;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
}

@media (max-width: 767px) {
  .also-like {
    padding: 40px 18px;
  }

  .also-like__heading {
    font-size: 28px;
    margin-bottom: 24px;
  }

  /* Mobile: 2x2 grid, 170x306 cards, 14px gap */
  .also-like__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
}
{% endstylesheet %}

<section class="also-like">
  <div class="also-like__inner">
    <h2 class="also-like__heading">{{ section.settings.heading | default: 'You might also like' }}</h2>

    <div class="also-like__grid">
      {% if section.settings.collection != blank %}
        {% assign al_collection = collections[section.settings.collection] %}
        {% for al_product in al_collection.products limit: 4 %}
          <div class="also-like-card">
            <div class="also-like-card__image-wrap">
              {% if al_product.featured_image %}
                <img
                  src="{{ al_product.featured_image | image_url: width: 600 }}"
                  alt="{{ al_product.featured_image.alt | default: al_product.title | escape }}"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <div class="also-like-card__body">
              <h3 class="also-like-card__title">{{ al_product.title }}</h3>
              <p class="also-like-card__price">{{ al_product.price | money }}</p>
              <a href="{{ al_product.url }}" class="also-like-card__btn">Shop Now</a>
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <div class="also-like-card">
            <div class="also-like-card__image-wrap"></div>
            <div class="also-like-card__body">
              <h3 class="also-like-card__title">Product Name</h3>
              <p class="also-like-card__price">₹0.00</p>
              <a href="#" class="also-like-card__btn">Shop Now</a>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "You Might Also Like",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You might also like"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "You Might Also Like"
    }
  ]
}
{% endschema %}

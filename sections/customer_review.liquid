<section class="reviews-section">

  <h2 class="reviews-heading">{{ section.settings.heading }}</h2>

  {% assign placeholder_reviews = "1,2,3" | split: "," %}
  {% assign has_blocks = false %}
  {% if section.blocks.size > 0 %}{% assign has_blocks = true %}{% endif %}

  <div class="reviews-carousel">

    {% if has_blocks %}

      {% for block in section.blocks %}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-image">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.author | escape }}">
            {% else %}
              <div class="review-image-placeholder"></div>
            {% endif %}
          </div>
          <div class="review-content">
            <span class="review-quote">&ldquo;</span>
            <div class="review-stars">
              {% for i in (1..block.settings.rating) %}
                <span class="star star--filled">&#9733;</span>
              {% endfor %}
              {% assign empty_stars = 5 | minus: block.settings.rating %}
              {% for i in (1..empty_stars) %}
                <span class="star star--empty">&#9733;</span>
              {% endfor %}
            </div>
            <p class="review-text">
              {% if block.settings.review != blank %}
                {{ block.settings.review }}
              {% else %}
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque euismod, nisi vel consectetur interdum.
              {% endif %}
            </p>
            <div class="review-author">
              {% if block.settings.author_avatar %}
                <img src="{{ block.settings.author_avatar | image_url: width: 60 }}" class="author-avatar" alt="{{ block.settings.author | escape }}">
              {% else %}
                <div class="author-avatar author-avatar-placeholder"></div>
              {% endif %}
              <span class="author-name">
                {% if block.settings.author != blank %}{{ block.settings.author }}{% else %}Author Name{% endif %}
              </span>
            </div>
          </div>
        </div>
      {% endfor %}

    {% else %}

      {% for item in placeholder_reviews %}
        <div class="review-card review-card--placeholder">
          <div class="review-image-placeholder"></div>
          <div class="review-content">
            <span class="review-quote">&ldquo;</span>
            <div class="review-stars">
              <span class="star star--filled">&#9733;</span>
              <span class="star star--filled">&#9733;</span>
              <span class="star star--filled">&#9733;</span>
              <span class="star star--filled">&#9733;</span>
              <span class="star star--filled">&#9733;</span>
            </div>
            <p class="review-text">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque euismod nisi vel consectetur interdum, vitae facilisis arcu condimentum.</p>
            <div class="review-author">
              <div class="author-avatar author-avatar-placeholder"></div>
              <span class="author-name">Customer Name</span>
            </div>
          </div>
        </div>
      {% endfor %}

    {% endif %}

  </div>

  {% assign dot_count = section.blocks.size %}
  {% if dot_count == 0 %}{% assign dot_count = 3 %}{% endif %}

  <div class="reviews-dots" aria-hidden="true">
    {% for i in (1..dot_count) %}
      <button class="reviews-dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to review {{ forloop.index }}"></button>
    {% endfor %}
  </div>

</section>


<script>
  (function() {
    const carousel = document.querySelector('.reviews-carousel');
    const dots = document.querySelectorAll('.reviews-dot');
    if (!carousel || !dots.length) return;

    dots.forEach(dot => {
      dot.addEventListener('click', function() {
        const index = parseInt(this.dataset.index);
        const cards = carousel.querySelectorAll('.review-card');
        if (cards[index]) {
          carousel.scrollTo({ left: cards[index].offsetLeft - carousel.offsetLeft, behavior: 'smooth' });
        }
      });
    });

    carousel.addEventListener('scroll', function() {
      const cards = Array.from(carousel.querySelectorAll('.review-card'));
      const scrollCenter = carousel.scrollLeft + carousel.offsetWidth / 2;
      let closest = 0;
      let minDist = Infinity;
      cards.forEach((card, i) => {
        const cardCenter = card.offsetLeft - carousel.offsetLeft + card.offsetWidth / 2;
        const dist = Math.abs(scrollCenter - cardCenter);
        if (dist < minDist) { minDist = dist; closest = i; }
      });
      dots.forEach((d, i) => d.classList.toggle('active', i === closest));
    }, { passive: true });
  })();
</script>


{% schema %}
{
  "name": "Customer Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hear from our Customers!"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Photo"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review",
          "label": "Review Text"
        },
        {
          "type": "image_picker",
          "id": "author_avatar",
          "label": "Author Avatar"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews"
    }
  ]
}
{% endschema %}

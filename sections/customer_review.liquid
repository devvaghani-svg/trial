<section class="reviews-section">

<h2>{{ section.settings.heading }}</h2>

<div class="reviews-grid">

{% for block in section.blocks %}

<div class="review-card">

<img src="{{ block.settings.image | image_url }}" />

<div class="review-content">

<div class="stars">
{% for i in (1..block.settings.rating) %}
⭐
{% endfor %}
</div>

<p>{{ block.settings.review }}</p>

<span class="author">
{{ block.settings.author }}
</span>

</div>

</div>

{% endfor %}

</div>

</section>

{% schema %}
{
"name": "Customer Reviews",
"settings":[
{
"type":"text",
"id":"heading",
"label":"Heading",
"default":"Hear from our Customers!"
}
],
"blocks":[
{
"type":"review",
"name":"Review",
"settings":[
{
"type":"image_picker",
"id":"image",
"label":"Customer Image"
},
{
"type":"range",
"id":"rating",
"label":"Rating",
"min":1,
"max":5,
"default":5
},
{
"type":"textarea",
"id":"review",
"label":"Review Text"
},
{
"type":"text",
"id":"author",
"label":"Author"
}
]
}
],
"presets":[
{
"name":"Customer Reviews"
}
]
}
{% endschema %}
{% stylesheet %}
.vet-check {
  padding: 60px 80px;
  background: #F9F3F1;
}

/* Desktop: white card 1064px wide, image left 532px, content right 450px */
.vet-check__inner {
  max-width: 1064px;
  margin: 0 auto;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 532px 1fr;
}

.vet-check__image {
  width: 100%;
  height: 300px;
  object-fit: cover;
  display: block;
  background: #eee;
}

.vet-check__content {
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16px;
}

.vet-check__text-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.vet-check__heading {
  font-size: 26px;
  font-weight: 700;
  color: #3a3a3e;
  margin: 0;
  line-height: 1.2;
}

.vet-check__text {
  font-size: 14px;
  color: #555;
  line-height: 1.6;
  margin: 0;
}

/* Button: 149x40, pad=(10,20,10,20), bg=#025a60 */
.vet-check__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #025A60;
  color: #fff;
  padding: 10px 20px;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  min-width: 149px;
  height: 40px;
  width: fit-content;
}

@media (max-width: 767px) {
  .vet-check {
    padding: 40px 18px;
  }

  /* Mobile: 354x314, image top 354x236, content below */
  .vet-check__inner {
    grid-template-columns: 1fr;
    border-radius: 12px;
  }

  .vet-check__image {
    height: 236px;
  }

  .vet-check__content {
    padding: 20px 14px;
    gap: 16px;
  }

  .vet-check__heading {
    font-size: 22px;
  }

  /* Mobile button: 115x30, pad=(6,10) */
  .vet-check__btn {
    min-width: 115px;
    height: 30px;
    padding: 6px 10px;
    font-size: 13px;
  }
}
{% endstylesheet %}

<section class="vet-check">
  <div class="vet-check__inner">
    {% if section.settings.image %}
      <img
        src="{{ section.settings.image | image_url: width: 900 }}"
        alt="{{ section.settings.image.alt | default: 'Veterinarian' | escape }}"
        class="vet-check__image"
        loading="lazy"
      >
    {% else %}
      <div class="vet-check__image"></div>
    {% endif %}

    <div class="vet-check__content">
      <div class="vet-check__text-group">
        <h2 class="vet-check__heading">{{ section.settings.heading | default: 'Check with my vet' }}</h2>
        {% if section.settings.text != blank %}
          <p class="vet-check__text">{{ section.settings.text }}</p>
        {% endif %}
      </div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_url | default: '#' }}" class="vet-check__btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vet Check",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Vet Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Check with my vet"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Consult Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Vet Check"
    }
  ]
}
{% endschema %}

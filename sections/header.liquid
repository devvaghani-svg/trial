<header class="custom-header">

  <!-- Teal announcement bar -->
  <div class="announcement-bar">
    <p class="announcement-bar__text">
      {{ section.settings.announcement_text | default: 'Free shipping on orders above ₹499 · Use code BELLIE10 for 10% off' }}
    </p>
  </div>

  <!-- Cream nav row -->
  <div class="header-nav-row">

    <!-- Logo -->
    <div class="header-logo">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | image_url }}"
            alt="{{ shop.name }}"
            style="max-width: {{ section.settings.logo_width }}px;"
            width="150"
            height="40"
          >
        {% else %}
          <span>{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- Desktop navigation -->
    <nav class="header-nav">
      <ul>
        {% for link in section.settings.menu.links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- Right icons -->
    <div class="header-icons">

      <a href="{{ routes.search_url }}" aria-label="Search">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>

      <a href="{{ routes.account_url }}" aria-label="Account">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" aria-label="Cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
      </a>

      <!-- Mobile hamburger -->
      <button class="header-hamburger" data-menu-toggle aria-expanded="false" aria-label="Open menu">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>

    </div>

  </div>

</header>


{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Bar Text",
      "default": "Free shipping on orders above ₹499 · Use code BELLIE10 for 10% off"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Header Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}

<section class="lafb-section">

  <div class="lafb-header">
    <h2 class="lafb-heading">{{ section.settings.heading | default: 'Love at First Bite.' }}</h2>
    <p class="lafb-subheading">{{ section.settings.subheading | default: 'Real dogs. Real reactions. Zero convincing required.' }}</p>
  </div>

  <div class="lafb-track-wrapper">
    <div class="lafb-track">

      {% if section.blocks.size > 0 %}

        {% for block in section.blocks %}
          <div
            class="lafb-item{% if forloop.first %} active{% endif %}"
            data-index="{{ forloop.index0 }}"
            data-description="{{ block.settings.description | escape }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.video_url != blank %}
              <a href="{{ block.settings.video_url }}" target="_blank" rel="noopener" class="lafb-link" aria-label="Watch video">
            {% else %}
              <div class="lafb-link">
            {% endif %}
              {% if block.settings.thumbnail %}
                <img
                  src="{{ block.settings.thumbnail | image_url: width: 600 }}"
                  alt="{{ block.settings.thumbnail.alt | default: 'Video thumbnail' | escape }}"
                  class="lafb-thumb"
                  loading="lazy"
                >
              {% else %}
                <div class="lafb-thumb lafb-thumb-placeholder"></div>
              {% endif %}
              <span class="lafb-play-btn" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
                  <polygon points="5,3 19,12 5,21"/>
                </svg>
              </span>
            {% if block.settings.video_url != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endfor %}

      {% else %}

        {% assign placeholder_descs = "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque euismod nisi vel consectetur interdum, vitae facilisis arcu condimentum.,Quisque facilisis erat a dui. Nam malesuada ornare dolor. Cras gravida diam sit amet rhoncus ornare erat.,Vestibulum ante ipsum primis in faucibus orci luctus. Sed euismod augue vel lorem tincidunt fermentum nunc aliquam.,Nulla facilisi. Morbi accumsan ipsum velit. Nam nec tellus a odio tincidunt auctor a ornare odio.,Aenean ligula eget dolor. Aenean massa. Cum sociis natoque penatibus et magnis dis parturient montes." | split: "," %}

        {% for i in (1..5) %}
          <div
            class="lafb-item{% if forloop.first %} active{% endif %}"
            data-index="{{ forloop.index0 }}"
            data-description="{{ placeholder_descs[forloop.index0] }}"
          >
            <div class="lafb-link">
              <div class="lafb-thumb lafb-thumb-placeholder"></div>
              <span class="lafb-play-btn" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
                  <polygon points="5,3 19,12 5,21"/>
                </svg>
              </span>
            </div>
          </div>
        {% endfor %}

      {% endif %}

    </div>

    <button type="button" class="lafb-next-btn" aria-label="Next">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9,18 15,12 9,6"/>
      </svg>
    </button>
  </div>

  <!-- Description panel -->
  {% assign first_desc = section.blocks[0].settings.description %}
  <div class="lafb-desc-box">
    <h3 class="lafb-desc-title">{{ section.settings.description_title | default: 'Description' }}</h3>
    <p class="lafb-desc-text" id="lafb-desc-text">
      {% if first_desc != blank %}
        {{ first_desc }}
      {% else %}
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque euismod nisi vel consectetur interdum, vitae facilisis arcu condimentum.
      {% endif %}
    </p>
  </div>

</section>


<script>
  (function() {
    const track = document.querySelector('.lafb-track');
    const nextBtn = document.querySelector('.lafb-next-btn');
    const descText = document.getElementById('lafb-desc-text');
    if (!track) return;

    // Click on item — update description
    track.querySelectorAll('.lafb-item').forEach(item => {
      item.addEventListener('click', function(e) {
        // Only intercept if no video URL (no <a> tag), otherwise let link open
        const desc = this.dataset.description;
        if (desc && descText) descText.textContent = desc;

        track.querySelectorAll('.lafb-item').forEach(i => i.classList.remove('active'));
        this.classList.add('active');
      });
    });

    // Next button (mobile)
    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        const item = track.querySelector('.lafb-item');
        if (!item) return;
        const gap = parseInt(getComputedStyle(track).gap) || 12;
        track.scrollBy({ left: (item.offsetWidth + gap) * 2, behavior: 'smooth' });
      });
    }
  })();
</script>


{% schema %}
{
  "name": "Love at First Bite",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Love at First Bite."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real dogs. Real reactions. Zero convincing required."
    },
    {
      "type": "text",
      "id": "description_title",
      "label": "Description Box Title",
      "default": "Description"
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video / Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail Image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "info": "Shown in the description box when this item is active"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Love at First Bite"
    }
  ]
}
{% endschema %}

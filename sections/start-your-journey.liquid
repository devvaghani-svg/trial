{% stylesheet %}
.start-journey {
  padding: 60px 80px;
  background: #F9F3F1;
}

.start-journey__inner {
  max-width: 1280px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 630px 628px;
  gap: 22px;
  align-items: center;
}

.start-journey__text {
  display: flex;
  flex-direction: column;
  gap: 48px;
}

.start-journey__heading {
  font-size: 36px;
  font-weight: 700;
  line-height: 1.2;
  color: #3a3a3e;
  margin: 0;
}

.start-journey__steps {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.journey-step {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}

.journey-step__number {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #E52888;
  color: #fff;
  font-weight: 700;
  font-size: 16px;
  line-height: 36px;
  text-align: center;
  flex-shrink: 0;
}

.journey-step__title {
  font-size: 16px;
  font-weight: 700;
  color: #3a3a3e;
  margin-bottom: 4px;
}

.journey-step__desc {
  font-size: 14px;
  color: #555;
  line-height: 1.5;
  margin: 0;
}

.start-journey__image-wrap {
  width: 100%;
}

.start-journey__image {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 12px;
  background: #eee;
  display: block;
}

@media (max-width: 767px) {
  .start-journey {
    padding: 40px 18px;
  }

  .start-journey__inner {
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .start-journey__image-wrap {
    order: -1;
  }

  .start-journey__image {
    border-radius: 8px;
  }

  .start-journey__heading {
    font-size: 28px;
  }

  .start-journey__text {
    gap: 24px;
  }
}
{% endstylesheet %}

<section class="start-journey">
  <div class="start-journey__inner">
    <div class="start-journey__text">
      <h2 class="start-journey__heading">{{ section.settings.heading | default: 'Start Your Journey With Wellie' }}</h2>

      {% if section.blocks.size > 0 %}
        <div class="start-journey__steps">
          {% for block in section.blocks %}
            <div class="journey-step" {{ block.shopify_attributes }}>
              <div class="journey-step__number">{{ forloop.index }}</div>
              <div class="journey-step__text">
                {% if block.settings.title != blank %}
                  <h3 class="journey-step__title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="journey-step__desc">{{ block.settings.description }}</p>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="start-journey__steps">
          <div class="journey-step">
            <div class="journey-step__number">1</div>
            <div class="journey-step__text">
              <h3 class="journey-step__title">Choose your size</h3>
              <p class="journey-step__desc">Select the pack size that suits your dog's weight and appetite.</p>
            </div>
          </div>
          <div class="journey-step">
            <div class="journey-step__number">2</div>
            <div class="journey-step__text">
              <h3 class="journey-step__title">Add to daily routine</h3>
              <p class="journey-step__desc">Give one Bellie Bite daily — treat it like a reward, not a supplement.</p>
            </div>
          </div>
          <div class="journey-step">
            <div class="journey-step__number">3</div>
            <div class="journey-step__text">
              <h3 class="journey-step__title">See the difference</h3>
              <p class="journey-step__desc">Notice improvements in gut health, coat, and energy within weeks.</p>
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="start-journey__image-wrap">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          class="start-journey__image"
          loading="lazy"
        >
      {% else %}
        <div class="start-journey__image"></div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Start Your Journey",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start Your Journey With Wellie"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Start Your Journey"
    }
  ]
}
{% endschema %}

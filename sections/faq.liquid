{% stylesheet %}
.faq-section {
  padding: 60px 80px;
  background: #F9F3F1;
}

.faq-section__inner {
  max-width: 1064px;
  margin: 0 auto;
}

/* Heading: 28px 700, 42px tall, gap=24px to list */
.faq-section__heading {
  font-size: 28px;
  font-weight: 700;
  color: #3a3a3e;
  margin-bottom: 24px;
  line-height: 42px;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* FAQ item: question 18px 700, + icon, answer 14px, 16px gap inside, 24px between items via border */
.faq-item {
  border-bottom: 1px solid rgba(0, 0, 0, 0.12);
}

.faq-item__question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
  cursor: pointer;
  font-size: 18px;
  font-weight: 700;
  color: #3a3a3e;
  background: none;
  border: none;
  width: 100%;
  text-align: left;
  gap: 24px;
  line-height: 1.3;
}

.faq-item__icon {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  transition: transform 0.25s ease;
}

.faq-item.open .faq-item__icon {
  transform: rotate(45deg);
}

.faq-item__answer {
  display: none;
  padding-bottom: 20px;
  font-size: 14px;
  color: #555;
  line-height: 1.7;
  margin: 0;
}

.faq-item.open .faq-item__answer {
  display: block;
}

@media (max-width: 767px) {
  .faq-section {
    padding: 40px 18px;
  }

  .faq-section__heading {
    font-size: 28px;
    margin-bottom: 24px;
  }

  .faq-item__question {
    font-size: 18px;
  }
}
{% endstylesheet %}

<section class="faq-section">
  <div class="faq-section__inner">
    <h2 class="faq-section__heading">{{ section.settings.heading | default: "FAQ's" }}</h2>

    <div class="faq-list">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="faq-item{% if forloop.first %} open{% endif %}" {{ block.shopify_attributes }}>
            <button
              type="button"
              class="faq-item__question"
              aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              {{ block.settings.question | default: 'Question goes here?' }}
              <svg class="faq-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <p class="faq-item__answer">
              {{ block.settings.answer | default: 'Answer goes here.' }}
            </p>
          </div>
        {% endfor %}
      {% else %}
        {% assign default_faqs = "Are Bellie Bites good for my dog?|Yes, Bellie Bites help prevent issues, boost nutrient absorption, boost immunity, improve poop quality, and improve breath.,I feed commercial food. Isn't that enough?|Commercial food alone often lacks the live probiotics and enzymes dogs need for optimal gut health. Bellie Bites fill that gap.,What's the difference from syrups or pills?|Bellie Bites are tastier and easier to give than syrups or pills, with better bioavailability and 4 billion CFUs per treat.,I give my dog curd — isn't that fine?|Curd is helpful but inconsistent in probiotic strains. Bellie Bites deliver 4 billion CFUs of clinically approved live strains." | split: "," %}
        {% for item in default_faqs %}
          {% assign parts = item | split: "|" %}
          <div class="faq-item{% if forloop.first %} open{% endif %}">
            <button type="button" class="faq-item__question" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
              {{ parts[0] }}
              <svg class="faq-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <p class="faq-item__answer">{{ parts[1] }}</p>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('.faq-item__question').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = this.closest('.faq-item');
        var isOpen = item.classList.contains('open');

        document.querySelectorAll('.faq-item').forEach(function (i) {
          i.classList.remove('open');
          i.querySelector('.faq-item__question').setAttribute('aria-expanded', 'false');
        });

        if (!isOpen) {
          item.classList.add('open');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }());
</script>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQ's"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ"
    }
  ]
}
{% endschema %}

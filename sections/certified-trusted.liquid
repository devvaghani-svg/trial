{% stylesheet %}
/* Desktop: 1440x203, bg=#d4e391, pad=(32,0,32,0), logos 60x60, gap=32px */
.certified-bar {
  background: #D4E391;
  padding: 32px 0;
  text-align: center;
  overflow: hidden;
}

.certified-bar__inner {
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.certified-bar__heading {
  font-size: 20px;
  font-weight: 700;
  color: #3a3a3e;
  margin: 0;
  text-align: center;
}

/* Logos row: 6 logos × 60px + 5 gaps × 32px = 360+160 = 520px — fits on desktop, scrolls on mobile */
.certified-bar__logos {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32px;
  padding: 0 80px;
  overflow-x: auto;
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.certified-bar__logos::-webkit-scrollbar {
  display: none;
}

.certified-bar__logo {
  width: 60px;
  height: 60px;
  object-fit: contain;
  flex-shrink: 0;
}

.certified-bar__logo-placeholder {
  width: 60px;
  height: 60px;
  background: rgba(0, 0, 0, 0.15);
  border-radius: 4px;
  flex-shrink: 0;
}

@media (max-width: 767px) {
  /* Mobile: 390x146, pad=(20,0,20,0), gap=20px */
  .certified-bar {
    padding: 20px 0;
  }

  .certified-bar__inner {
    gap: 20px;
  }

  .certified-bar__logos {
    padding: 0 18px;
    justify-content: flex-start;
    gap: 32px;
  }
}
{% endstylesheet %}

<section class="certified-bar">
  <div class="certified-bar__inner">
    <h2 class="certified-bar__heading">{{ section.settings.heading | default: 'Certified & Trusted' }}</h2>

    <div class="certified-bar__logos">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div {{ block.shopify_attributes }}>
            {% if block.settings.logo %}
              <img
                src="{{ block.settings.logo | image_url: width: 120 }}"
                alt="{{ block.settings.alt_text | default: 'Certification' | escape }}"
                class="certified-bar__logo"
                loading="lazy"
              >
            {% else %}
              <div class="certified-bar__logo-placeholder"></div>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..6) %}
          <div class="certified-bar__logo-placeholder"></div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Certified & Trusted",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Certified & Trusted"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Certification Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certified & Trusted"
    }
  ]
}
{% endschema %}
